# Variáveis de ambiente do WhatsCoach
# Copie este arquivo para ".env" no desenvolvimento local e preencha os valores.
# Na Netlify, configure as mesmas variáveis em:
#   Site settings > Build & deploy > Environment > Environment variables

# --- Supabase (servidor) ---
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=

# --- Supabase (cliente / expostas no bundle via Vite) ---
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
